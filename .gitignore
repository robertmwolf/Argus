!data/sample/.gitkeep

# Results — check in JSON metrics, not raw outputs
results/*.png
results/*.csv

# Credentials — never commit
.env.local
.envrc
secrets.json

# Claude Code local settings (machine-specific paths)
.claude/settings.local.json

# OS
.DS_Store
Thumbs.db

# IDE
