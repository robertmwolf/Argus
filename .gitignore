# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/

# Virtual environments / conda
.env
.venv
env/
venv/
ENV/

# Data — never check in raw FITS or large archives
data/cache/
data/GTImages/*.fits
data/GTImages/*.fit
data/GTImages/*.fts
*.fits
*.fit
*.fts
*.zip

# Keep sample placeholder
!data/sample/.gitkeep

# Results — check in JSON metrics, not raw outputs
results/*.png
results/*.csv
# Large raw prediction/proposal dumps (regenerable, too big for git)
results/*/proposals*.json
results/**/proposals*.json
results/*/predictions.json
results/**/predictions.json
results/**/*predictions.json
results/**/*.bbox.json
# Threshold-sweep prediction dumps (predictions_t070.json etc.) — regenerable
results/**/predictions_t*.json
# Per-threshold metrics files — summary geometry_eval.json is enough
results/**/metrics_t*.json
results/**/metrics_placeholder.json
# Claude Code dev artifacts
.claude/launch.json
.claude/scheduled_tasks.lock
# Credentials — never commit
.env.local
.envrc
secrets.json

# Claude Code local settings and worktree scratch space (machine-specific)
.claude/settings.local.json
.claude/worktrees/
.claude/launch.json
.claude/scheduled_tasks.lock

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Testing
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Logs
*.log

# Model weights
# DINOv3 pretrained backbones are Meta's property — never commit
weights/dinov3_*.pth
# Trained ARGUS weights (weights/*/best.pt etc.) are tracked in git

# Training logs and checkpoints
training/logs/
training/work_dirs/

# SQLite dev database
*.db
*.db-shm
*.db-wal
argus*.db
argus.db-*

# Docker uploads volume (local dev)
data/uploads/

# TLE source data — large archives, never commit
data/tle_zips/

# Eval per-image prediction dumps (large, regenerated by benchmark)
eval/results/*.json

# Training data lives outside the repository; configure ARGUS_DATA_ROOT.
# Ignore accidental local directories, but do not use repository symlinks.
data/BrentImages/
data/satstreaks/
data/dev_subset/
data/raw/
data/processed/
data/augmented/
data/gtimages_synthetic/
data/annotations/

runs/
