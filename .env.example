# Copy to .env and fill in your credentials.
# .env is gitignored — never commit real credentials.

# Space-Track (only needed for explicit TLE catalog maintenance)
SPACETRACK_USER=your@email.com
SPACETRACK_PASS=yourpassword
# Local development uses the Space-Track test site by default.
# Set ARGUS_ENV=production for production defaults, or override explicitly:
ARGUS_ENV=development
SPACETRACK_BASE_URL=https://for-testing-only.space-track.org/

# Database (override the docker-compose default if needed)
# DATABASE_URL=postgresql+asyncpg://argus:argus@db/argus

# Active endpoint heatmap detectors. Checkpoint overrides are only needed when
# weights are not installed at the detector's built-in weights/... default.
# VITS_HEATMAP_CHECKPOINT=/path/to/vits/best.pt
# VITB_HEATMAP_CHECKPOINT=/path/to/vitb/best.pt
# VITS_V4_HEATMAP_CHECKPOINT=/path/to/vits-window-v4/best.pt
# VITS_V9_HEATMAP_CHECKPOINT=/path/to/vits-window-v9/best.pt
# VITB_V4_HEATMAP_CHECKPOINT=/path/to/vitb-window-v4/best.pt

# Optional detector tuning. Omitted values use the defaults in each detector.
# VITS_HEATMAP_THRESHOLD=0.7
# VITS_HEATMAP_PEAK_FLOOR=0.85
# VITS_HEATMAP_MAX_LONG_EDGE=3200
# VITB_HEATMAP_THRESHOLD=0.7
# VITB_HEATMAP_PEAK_FLOOR=0.85
# VITB_HEATMAP_MAX_LONG_EDGE=3200

# Default preprocessing for FITS loading. Per-detector *_NORM overrides this
# when a model was trained with a different normalization mode.
# ARGUS_NORM=autostretch
# VITS_HEATMAP_NORM=zscore
# VITB_HEATMAP_NORM=zscore
# VITS_V4_HEATMAP_NORM=zscore
# VITS_V9_HEATMAP_NORM=zscore
# VITB_V4_HEATMAP_NORM=zscore

# Useful on Apple Silicon when an MPS operation needs a CPU fallback.
# PYTORCH_ENABLE_MPS_FALLBACK=1

# Training data lives outside the repository. The optional scratch mirror is
# checked first so train/validation reads can use a local SSD.
# ARGUS_DATA_ROOT=/Volumes/External/TrainingData
# ARGUS_SCRATCH_ROOT=/tmp/argus-data

# Plate solving — set to true to run ASTAP when the FITS header lacks WCS.
# Header hints constrain the solve but do not enable it automatically.
# ARGUS_ENABLE_PLATE_SOLVE=true

# Cloud storage (only needed with STORAGE_BACKEND=s3)
# STORAGE_BACKEND=s3
# S3_BUCKET=your-bucket-name
# AWS_REGION=us-east-1

# Cloud queue (only needed with QUEUE_BACKEND=sqs)
# QUEUE_BACKEND=sqs
