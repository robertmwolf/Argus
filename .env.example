# Copy to .env and fill in your credentials.
# .env is gitignored — never commit real credentials.

# Space-Track (required for satellite cross-identification)
SPACETRACK_USER=your@email.com
SPACETRACK_PASS=yourpassword
# Local development uses the Space-Track test site by default.
# Set ARGUS_ENV=production for production defaults, or override explicitly:
ARGUS_ENV=development
SPACETRACK_BASE_URL=https://for-testing-only.space-track.org/

# Database (override the docker-compose default if needed)
# DATABASE_URL=postgresql+asyncpg://argus:argus@db/argus

# Model selection — two options:
#
# Option A: single model via MODEL_SIZE (tiny | dinov3_vitb | dinov3_vitl | large)
MODEL_SIZE=tiny
#
# Option B: multi-model via ARGUS_MODEL_CONFIGS (JSON array, exposes all in the UI).
# Example with two DINOv3 ViT-B checkpoints:
# ARGUS_MODEL_CONFIGS=[{"id":"dinov3_vitb","size":"dinov3_vitb","weights":"weights/dinov3_vitb_augmented/best_coco_bbox_mAP_epoch_10.pth","label":"DINOv3 Base","dataset":"SatStreaks+GTImages"},{"id":"dinov3_vitb_multisource","size":"dinov3_vitb_multisource","weights":"weights/run_best_400px_nodm/best_coco_bbox_mAP_epoch_15.pth","label":"DINOv3 Base - Multi-source","dataset":"SatStreaks+BrentImages+Frigate"}]

CONFIDENCE_THRESHOLD=0.01

# Cloud storage (only needed with STORAGE_BACKEND=s3)
# STORAGE_BACKEND=s3
# S3_BUCKET=your-bucket-name
# AWS_REGION=us-east-1

# Cloud queue (only needed with QUEUE_BACKEND=sqs)
# QUEUE_BACKEND=sqs
